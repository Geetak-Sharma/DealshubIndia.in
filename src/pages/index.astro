            </button>

            <div class="archive-scroll" id="archive-scroll">
              {archiveDeals.map((deal, idx) => (
                <div class="archive-card" style={`animation-delay: ${idx * 40}ms`}>
                  <DealCard 
                    title={deal.title}
                    image={deal.image}
                    price={deal.price}
                    originalPrice={deal.originalPrice}
                    discount={deal.discount}
                    url={deal.url}
                    platform={deal.platform}
                    badge="⏳ Expired"
                    timestamp={deal.timestamp}
                  />
                </div>
              ))}
            </div>

            <button class="archive-chevron archive-chevron--right" aria-label="Scroll right" type="button">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>

          <div class="action-footer">
            <a href="/livedeals" class="c-btn c-btn--primary view-more-btn">
              View All Deals &rarr;
            </a>
          </div>
        </section>
        );
      })()}

      <SectionBlock title="Join Priority Networks" icon="🤝">
