      </div>
      
      {fetchError && (
         <div class="error-slate">
           <h3>Oops! No deals available right now.</h3>
           <p>Our scouts are fetching the latest loots. Please check back in a few minutes.</p>
           <small>{fetchError}</small>
         </div>
      )}
      
      <!-- DOM Empty Search Fallback State (Hidden Automatically) -->
      <div id="no-search-results" class="error-slate hidden-slate">
         <h3>No items match your search.</h3>
         <p>Try modifying your query or checking back later.</p>
      </div>

      {/* MAIN DEAL GRID */}
      {deals.length > 0 && (
        <section class="l-section">
          <div class="section-header u-flex u-items-center u-mb-3">
            <h2 class="section-title">🔥 Today's Best Deals</h2>
          </div>

          <div id="premium-grid" class="deals-grid">
            {deals.slice(0, 8).map((deal, idx) => (
              <div
                class="deal-card-wrapper"
                data-title={deal.title.toLowerCase()}
                data-category={deal.category}
                data-price-num={deal.priceNum}
                data-is-loot={deal.isLoot ? 'true' : 'false'}
                style={`animation-delay: ${idx * 60}ms`}
              >
                <DealCard 
                  title={deal.title}
                  image={deal.image}
                  price={deal.price}
                  originalPrice={deal.originalPrice}
                  discount={deal.discount}
                  url={deal.url}
                  platform={deal.platform}
                  badge={deal.badge}
                  timestamp={deal.timestamp}
                  isLoot={deal.isLoot}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      {/* ===== OLD DEALS — Horizontal Scroll Archive ===== */}
      {deals.length > 0 && (() => {
        // Mock: duplicate existing deals 5x to test scroll physics
        const archiveDeals = [...deals, ...deals, ...deals, ...deals, ...deals].slice(0, 20);
        return (
        <section class="l-section archive-section">
          <div class="section-header u-flex u-items-center u-mb-3">
            <h2 class="section-title">🕒 Recently Expired / Older Drops</h2>
          </div>

          <div class="archive-scroll-wrap">
            <button class="archive-chevron archive-chevron--left" aria-label="Scroll left" type="button">
