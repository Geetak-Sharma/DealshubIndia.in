---

<Layout title="DealshubIndia.in: Best Deals & Offers Today">
  <StickyHeader />
  
  <main>
    <!-- Premium Hero Section -->
    <div class="hero-section glass-panel u-mb-6 fade-in-up">
      <div class="l-container">
        <div class="hero-content u-py-6">
          <div class="attention-hook u-mb-3">
             🔥 50+ Live Deals <span class="dot-sep">•</span> 🕒 Updated live
          </div>
          <h1 class="u-text-4xl u-font-black u-text-white u-mb-2">Best Loot Deals & <span class="u-text-green">Offers in India</span></h1>
          <p class="u-text-lg u-text-secondary">Scouring the internet for the biggest price drops, since 2018.</p>
        </div>
      </div>
    </div>

    <div class="l-container u-mb-4">
      
      <div id="deals-grid" class="deals-grid">
         {/* Hydrated via script below */}
         <div class="skeleton-slate">Fetching latest loots...</div>
      </div>

      <script is:inline>
        async function loadDeals() {
          const grid = document.getElementById('deals-grid');
          try {
            // Use relative path for GCP stability
            const res = await fetch('/api/deals');
            const data = await res.json();

            if (data.error || !data.length) {
              grid.innerHTML = '<p class="glass-panel">No live loots at the moment. Check back soon!</p>';
              return;
            }

            grid.innerHTML = data.map(deal => `
              <div class="deal-card-wrapper glass-panel spring-hover" 
                   data-title="${deal.title}" 
                   data-category="${deal.category}" 
                   data-price="${deal.price.replace(/[^0-9]/g, '')}"
                   data-is-loot="${deal.isLoot}">
                <div class="deal-card-content">
                  <div class="deal-badge ${deal.isLoot ? 'loot-tag' : ''}">${deal.category}</div>
                  <h3 class="u-text-base u-font-bold u-mb-1">${deal.title}</h3>
                  <div class="price-stack">
                    <span class="price-current">₹${deal.price}</span>
                    ${deal.originalPrice ? `<span class="price-old">₹${deal.originalPrice}</span>` : ''}
                  </div>
                  <a href="${deal.link}" target="_blank" rel="noopener" class="btn btn--primary u-mt-2">View Loot</a>
                </div>
              </div>
            `).join('');
          } catch (e) {
            console.error("Frontend Fetch Error:", e);
            grid.innerHTML = '<p class="glass-panel">Failed to load deals. Please refresh.</p>';
          }
        }
        loadDeals();
      </script>

      <SectionBlock title="Join Priority Networks" icon="🤝">
        <BentoGrid items={bentoItems} client:visible />
      </SectionBlock>

      <footer class="footer-master">
        <div class="footer-grid">
          <div class="footer-col brand-col">
            <h4>DealshubIndia<span class="logo-accent">.in</span></h4>
            <p>Best deals from Amazon, Flipkart & more</p>
          </div>
          <div class="footer-col">
            <h4>Quick Links</h4>
            <a href="/">Latest Drops</a>
            <a href="/livedeals">Live Deals Archive</a>
            <a href="/">Categories</a>
          </div>
          <div class="footer-col">
            <h4>Social Networks</h4>
            <a href="https://whatsapp.com/channel/0029Va8sOrp4SpkEQKVElV1i" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            <a href="https://t.me/DealsHubIndiaa" target="_blank" rel="noopener noreferrer">Telegram</a>
            <a href="https://www.instagram.com/dealshubindia.in" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://www.youtube.com/@geetaksharma" target="_blank" rel="noopener noreferrer">YouTube</a>
          </div>
          <div class="footer-col">
            <h4>Trust & Verification</h4>
            <p>Deals updated every few minutes directly from our active scouts.</p>
            <a href="/disclosure">Affiliate Disclaimer</a>
            <a href="/dmca">Protocol & DMCA</a>
          </div>
        </div>
        <div class="footer-identity">
          <p>Made for deal hunters in India 🇮🇳</p>
        </div>
      </footer>
      
    </div>
  </main>

  <FloatingWhatsApp />
