    </div>
  </main>

  <FloatingWhatsApp />
</Layout>

<!-- Core DOM Interaction Logic mapping Search UI natively -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const allWrappers = Array.from(document.querySelectorAll('.deal-card-wrapper'));
    const noResultsDiv = document.getElementById('no-search-results');
    let isSearchActive = false;

    // Material UI Search Custom Event Listener
    window.addEventListener('deals-search', (e) => {
      const query = e.detail.query.toLowerCase();
      isSearchActive = query.length > 0;
      let visibleCount = 0;

      allWrappers.forEach(wrapper => {
        const titleText = wrapper.getAttribute('data-title') || '';
        
        if (!isSearchActive) {
          wrapper.classList.remove('is-search-hidden');
          return;
        }

        if (titleText.includes(query)) {
          wrapper.classList.remove('is-search-hidden');   
          wrapper.classList.add('fade-in-up'); 
          visibleCount++;
        } else {
          wrapper.classList.add('is-search-hidden'); 
        }
      });

      if (noResultsDiv) {
        noResultsDiv.style.display = (isSearchActive && visibleCount === 0) ? 'block' : 'none';
      }
    });

    // Category Chips Filter
    window.addEventListener('deals-category', (e) => {
      const category = e.detail.category;
      let visibleCount = 0;

      allWrappers.forEach(wrapper => {
        const itemCat = wrapper.getAttribute('data-category');
        const itemIsLoot = wrapper.getAttribute('data-is-loot') === 'true';
        
        let show = false;
        if (category === 'all') {
            show = true;
        } else if (category === 'tech' && itemCat === 'tech') {
            show = true;
        } else if (category === 'fashion' && itemCat === 'fashion') {
            show = true;
        } else if (category === 'home' && itemCat === 'home') {
            show = true;
        } else if (category === 'under-99' && itemCat === 'under-99') {
            show = true;
        } else if (category === 'loots' && itemIsLoot) {
            // Note: The chip for "All Loots" has data-category="all"
            // If we want a specific "Only Loots" filter, we'd use this.
            show = true;
        }

        if (show) {
          wrapper.classList.remove('is-search-hidden');
          visibleCount++;
        } else {
          wrapper.classList.add('is-search-hidden');
        }
      });
      
      if (noResultsDiv) {
        noResultsDiv.style.display = (visibleCount === 0) ? 'block' : 'none';
      }
    });

  });
</script>

<!-- Archive Scroll Chevrons -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const scroll = document.getElementById('archive-scroll');
    if (!scroll) return;

    const leftBtn = document.querySelector('.archive-chevron--left');
    const rightBtn = document.querySelector('.archive-chevron--right');
    const scrollAmount = 600;

    if (leftBtn) leftBtn.addEventListener('click', () => {
      scroll.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    if (rightBtn) rightBtn.addEventListener('click', () => {
      scroll.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  });
</script>

<style>
  main {
    padding-bottom: var(--spacing-6); 
  }

  /* Structural Hide Overrides safely isolated using !important to prevent CSS cascade failures */
  .deal-card-wrapper.is-search-hidden {
    display: none !important;
  }

  .hidden-slate {
    display: none;
  }
  
  .action-footer {
    display: flex;
    justify-content: center;
    padding-top: var(--spacing-4);
    margin-top: var(--spacing-3);
  }

  .view-more-btn {
    padding: 14px 40px !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    border-radius: 12px !important;
    letter-spacing: 0.5px;
  }

  /* Staggered load animation on wrappers */
  .deal-card-wrapper {
    animation: wrapperFade 0.5s ease both;
  }
  @keyframes wrapperFade {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .error-slate {
    background-color: var(--surface-color);
    border: 1px dashed var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-4);
    text-align: center;
    margin: var(--spacing-3) 0;
  }

  .error-slate h3 { margin-bottom: var(--spacing-1); color: var(--text-primary); }
  .error-slate p { color: var(--text-secondary); margin-bottom: var(--spacing-2); }
  .error-slate small { color: var(--text-muted); }
  
  .attention-hook {
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    background-color: var(--surface-color);
    border: 1px solid var(--border-color);
    padding: 8px 16px;
    border-radius: var(--radius-full);
    display: inline-block;
    margin: 0 auto var(--spacing-4) auto;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: var(--shadow-sm);
  }

  .dot-sep {
    color: var(--border-color);
    margin: 0 6px;
    font-weight: bold;
  }
  
  .footer-master {
    margin-top: var(--spacing-6);
    padding: var(--spacing-5) var(--spacing-4);
    background-color: var(--surface-color);
    border: 1px solid rgba(150, 150, 150, 0.1);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  [data-theme='dark'] .footer-master {
    background-color: rgba(0, 0, 0, 0.15); /* Slightly darker than main body */
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-4);
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .footer-grid { grid-template-columns: repeat(4, 1fr); padding-bottom: var(--spacing-3); border-bottom: 1px solid var(--border-color); }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-col h4 {
    color: var(--text-primary);
    font-size: 15px;
    margin-bottom: 4px;
    font-weight: 700;
  }

  .brand-col h4 {
    font-size: 18px;
    font-weight: 800;
  }

  .footer-col a, .footer-col p {
    color: var(--text-secondary);
    font-size: 14px;
    text-decoration: none;
    line-height: 1.4;
  }

  .footer-col a:hover {
    color: var(--primary-color);
    text-decoration: underline;
  }

  .footer-identity {
    text-align: center;
    padding-top: var(--spacing-4);
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* ===== Section Title ===== */
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--spacing-3);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 40%;
    height: 3px;
    background-color: #22C55E;
    border-radius: 2px;
  }

  /* ===== ARCHIVE HORIZONTAL SCROLL ===== */
  .archive-section {
    overflow: hidden;
  }

  .archive-scroll-wrap {
    position: relative;
  }

  .archive-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: 8px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .archive-scroll::-webkit-scrollbar {
    display: none;
  }

  .archive-card {
    flex: 0 0 280px;
    scroll-snap-align: start;
    animation: archiveSlide 0.4s ease both;
  }

  @keyframes archiveSlide {
    from { opacity: 0; transform: translateX(16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* Grayscale + reduced opacity for expired cards */
  .archive-card .deal-card__img {
    filter: grayscale(40%) brightness(0.85);
    transition: filter 0.3s ease, transform 0.4s ease;
  }

  .archive-card:hover .deal-card__img {
    filter: grayscale(0%) brightness(1);
  }

  .archive-card .deal-card {
    opacity: 0.85;
    transition: opacity 0.3s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .archive-card:hover .deal-card {
    opacity: 1;
  }

  /* ---- Chevron Scroll Buttons ---- */
  .archive-chevron {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: var(--surface-color);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    box-shadow: var(--shadow-md);
  }

  .archive-scroll-wrap:hover .archive-chevron {
    opacity: 1;
  }

  .archive-chevron:hover {
    background: #22C55E;
    color: white;
    border-color: #22C55E;
    box-shadow: 0 4px 16px rgba(34, 197, 94, 0.35);
  }

  .archive-chevron--left {
    left: -4px;
  }

  .archive-chevron--right {
    right: -4px;
  }

  @media (max-width: 640px) {
    .archive-chevron {
      display: none;
    }
  }

  /* ===== SKELETON LOADING PULSE ===== */
  .skeleton-card {
    background: var(--surface-color);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    animation: skeletonPulse 1.5s ease-in-out infinite;
  }

  .skeleton-card__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--surface-color-hover);
  }

  .skeleton-card__body {
