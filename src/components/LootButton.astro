const colors = {
  whatsapp: 'bg-[#25D366]',
  telegram: 'bg-[#0088cc]',
  instagram: 'bg-[#E1306C]',
  youtube: 'bg-[#FF0000]'
};
---

<a 
  href={href} 
  target="_blank" 
  rel="noopener noreferrer" 
  class={`loot-pill ${colors[type]}`}
  style={`color: var(--pill-text);`}
>
  <div class="pill-icon" set:html={icons[type]} />
  <div class="pill-text">{label}</div>
</a>
