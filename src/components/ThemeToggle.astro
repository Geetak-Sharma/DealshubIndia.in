---
---
<button id="theme-toggle" aria-label="Toggle System Theme" class="tap-ios">
  <div class="icon-container">
    <svg id="sun" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
    <svg id="moon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
  </div>
</button>

<script>
  function initTheme() {
    const toggle = document.getElementById('theme-toggle');
    const sun = document.getElementById('sun');
    const moon = document.getElementById('moon');
    
    if (!toggle) return;

    const getTheme = () => localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    
    const setTheme = (theme) => {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      if (theme === 'dark') {
        sun?.classList.remove('hidden');
        moon?.classList.add('hidden');
      } else {
        sun?.classList.add('hidden');
        moon?.classList.remove('hidden');
      }
    };

    // Initial sync
    setTheme(getTheme());

    toggle.addEventListener('click', () => {
      const theme = getTheme() === 'light' ? 'dark' : 'light';
      setTheme(theme);
    });
  }

  // Run on initial load and after View Transitions
  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>

<style>
  #theme-toggle {
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    padding: 1rem;
    border-radius: 1.5rem;
    cursor: pointer;
    box-shadow: var(--card-shadow);
    transition: transform 0.2s cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  #theme-toggle:active {
    transform: scale(0.9);
  }

  .hidden {
    display: none;
  }

  svg {
    stroke: var(--text-primary);
  }
</style>
