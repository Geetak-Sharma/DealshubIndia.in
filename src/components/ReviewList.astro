---
// src/components/ReviewList.astro
const { url } = Astro.props;

// Component logic: Fetch reviews client-side or during SSR?
// Since we want "Smart Review Layer", we fetch client-side for dynamic data.
---
<div class="review-container" data-url={url}>
  <div class="review-header">
    <h3>Community Insights</h3>
    <div class="loading-indicator">Fetching latest reviews...</div>
  </div>
  <div class="reviews-list" id="review-list">
    <!-- Reviews injected here -->
  </div>
</div>

<script>
  async function loadReviews() {
    const container = document.querySelector('.review-container');
    const list = document.getElementById('review-list');
    const loader = document.querySelector('.loading-indicator');
    const url = container?.getAttribute('data-url');

    if (!url || !list) return;

    try {
      const res = await fetch(`/api/reviews?url=${encodeURIComponent(url)}`);
      const data = await res.json();

      if (data.reviews && data.reviews.length > 0) {
        loader.style.display = 'none';
        list.innerHTML = data.reviews.map(r => `
          <div class="review-card">
            <div class="review-card__header">
              <span class="rating-badge">${r.rating} ★</span>
              <span class="review-title">${r.title}</span>
            </div>
            <p class="review-body">${r.body}</p>
          </div>
        `).join('');
      } else {
        loader.innerHTML = 'No detailed reviews found for this offer.';
      }
    } catch (e) {
      loader.innerHTML = 'Failed to load reviews. Check the original store.';
    }
  }

  // Load reviews when visible
  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      loadReviews();
      observer.disconnect();
    }
  });

  const target = document.querySelector('.review-container');
  if (target) observer.observe(target);
</script>

<style>
  .review-container {
    background: var(--surface-color);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-4);
    margin-top: var(--spacing-4);
  }

  .review-card {
    border-bottom: 1px solid var(--border-color);
    padding: var(--spacing-3) 0;
  }

  .review-card:last-child { border-bottom: none; }

  .rating-badge {
    background: #22C55E;
    color: white;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: bold;
    margin-right: 8px;
  }

  .review-title { font-weight: 700; color: var(--text-primary); }
  .review-body { font-size: 14px; color: var(--text-secondary); margin-top: 4px; }
  .loading-indicator { color: var(--text-muted); font-size: 14px; }
</style>
