<div class="footer-stick">
  <div class="max-w-[500px] w-full px-4">
    <a href="https://whatsapp.com/channel/0029Va9WpU65Ui2TjWlI6G1D" target="_blank" rel="noopener noreferrer" class="footer-btn tap-ios">
      Join WhatsApp for Loots
    </a>
  </div>
</div>

<style>
  .footer-stick {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1.5rem 0;
    z-index: 9999;
    display: flex;
    justify-content: center;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .footer-btn {
    background-color: #25D366;
    color: white;
    width: 100%;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1.5rem;
    font-weight: 900;
    text-decoration: none;
    font-size: 1.125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    box-shadow: 0 20px 40px -10px rgba(37, 211, 102, 0.4);
  }

  .tap-ios {
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tap-ios:active {
    transform: scale(0.95);
  }
</style>
